# ==== Telegram ====
TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_ADMIN_IDS=123456789
SUPPORT_URL=https://t.me/your_support_username
PUBLIC_OFFER_URL=https://example.com/oferta

# ==== Database ====
DATABASE_URL=sqlite+aiosqlite:///data/storage/bot.db

# ==== Google Sheets ====
GOOGLE_SHEET_ID=replace_with_sheet_id
GOOGLE_INVENTORY_WORKSHEET=inventory
GOOGLE_SALES_WORKSHEET=sales
# Legacy fallback for older deployments. Can be left empty.
GOOGLE_ORDERS_WORKSHEET=

# Use one of the three options below.
# GOOGLE_SERVICE_ACCOUNT_JSON_B64 must be base64 of the full service account JSON file.
GOOGLE_SERVICE_ACCOUNT_FILE=/absolute/path/to/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# ==== GPT stock CSV ====
# Use a direct CSV export URL or local path.
CHATGPT_STOCK_CSV_URL=
CHATGPT_STOCK_CSV_PATH=
CHATGPT_STOCK_RESERVE_MINUTES=20

# ==== YooKassa ====
YOOKASSA_SHOP_ID=replace_me
YOOKASSA_SECRET_KEY=replace_me
YOOKASSA_RETURN_URL=https://your-domain.tld/payment-return
YOOKASSA_API_BASE=https://api.yookassa.ru/v3
YOOKASSA_VAT_CODE=1
YOOKASSA_TAX_SYSTEM_CODE=
