# ==== Telegram ====
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:replace_me
# ID админов через запятую: 111111,222222
TELEGRAM_ADMIN_IDS=123456789
# Ссылка на поддержку (кнопка "Поддержка")
SUPPORT_URL=https://t.me/your_support_username

# ==== Local Storage ====
# SQLite по умолчанию. Можно заменить на Postgres URL.
DATABASE_URL=sqlite+aiosqlite:///data/storage/bot.db
# Куда сохранять выданные CSV
EXPORT_DIR=data/storage/exports

# ==== Google Sheets ====
# ID таблицы из URL
GOOGLE_SHEET_ID=replace_with_sheet_id
# Путь до JSON ключа сервисного аккаунта
GOOGLE_SERVICE_ACCOUNT_FILE=/absolute/path/to/google-service-account.json
# Названия листов
GOOGLE_INVENTORY_WORKSHEET=inventory
GOOGLE_SALES_WORKSHEET=sales

# ==== Crypto Bot ====
# Включить/выключить кнопку "Криптой"
CRYPTOBOT_ENABLED=true
# API endpoint Crypto Bot
CRYPTOBOT_API_BASE=https://pay.crypt.bot/api
# API token из @CryptoBot
CRYPTOBOT_API_TOKEN=
# Валюта инвойса (например: USDT, TON, BTC)
CRYPTOBOT_ASSET=USDT
# Кнопка "Удобно купить крипту тут" в экране оплаты
CRYPTO_BUY_URL=https://t.me/send?start=r-t3x5q-market

# ==== Payment Test (временно для реальных проверок webhook) ====
# true: для выбранного товара применяет тестовую цену в крипте
PAYMENT_TEST_ENABLED=false
# slug товара, на который распространяется тест (например gpt-pro-1m)
PAYMENT_TEST_PRODUCT_SLUG=gpt-pro-1m
# $1.00
PAYMENT_TEST_CRYPTO_PRICE_CENTS=100

# ==== Test Mode ====
# true: показывает кнопку "Тест: без оплаты"
TEST_MODE_ENABLED=false
# true: тестовый режим только для админов
TEST_MODE_ADMIN_ONLY=true
